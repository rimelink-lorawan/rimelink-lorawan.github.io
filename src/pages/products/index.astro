---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const allProducts = await getCollection('products');
const products = allProducts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

function productIcon(product: typeof products[number]) {
  if (product.data.image) {
    return `<img src="${product.data.image}" alt="${product.data.title}" class="w-full h-full object-contain p-2" />`;
  }
  return `<svg class="w-7 h-7 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="3" stroke-width="1.5"/><path d="M8 12h8M8 8h4M8 16h4" stroke-width="1.5" stroke-linecap="round"/></svg>`;
}
---

<BaseLayout title="产品中心 - 锐米 RimeLink">
  <Header />

  <main class="pt-8 pb-20">
    {/* Page header */}
    <section class="bg-gradient-to-br from-primary-600 to-primary-800 text-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 lg:py-20">
        <div class="max-w-3xl">
          <div class="inline-flex items-center gap-2 bg-white/20 rounded-full px-4 py-1.5 text-sm mb-4">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
            产品中心
          </div>
          <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold mb-4">LoRaWAN 产品</h1>
          <p class="text-lg text-white/80 leading-relaxed">
            提供端到端的物联网解决方案。
          </p>
        </div>
      </div>
    </section>

    {/* Product list */}
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 -mt-8">
      <div class="grid gap-6">
        {products.map((product) => {
          const tag = product.data.tag;
          return (
            <a
              href={`/products/${product.slug}/`}
              class="group bg-white rounded-2xl border border-gray-100 p-6 lg:p-8 hover:shadow-xl hover:border-primary-200 transition-all duration-300 flex flex-col sm:flex-row gap-6 items-start relative overflow-hidden"
            >
              {/* Tag */}
              {tag && (
                <span
                  class={`absolute top-4 right-4 text-xs font-semibold px-3 py-1 rounded-full z-10 ${
                    tag === '热销' ? 'bg-red-50 text-red-600' :
                    tag === '新品' ? 'bg-green-50 text-green-600' :
                    'bg-blue-50 text-blue-600'
                  }`}
                >
                  {tag}
                </span>
              )}

              {/* Image or Icon */}
              <div class="w-24 h-24 sm:w-28 sm:h-28 rounded-2xl bg-gray-100 flex items-center justify-center shrink-0 group-hover:scale-105 transition-transform duration-300 overflow-hidden" set:html={productIcon(product)}>
              </div>

              {/* Content */}
              <div class="flex-1 min-w-0">
                <h3 class="text-lg font-bold text-gray-900 mb-1 group-hover:text-primary-600 transition-colors">
                  {product.data.title}
                </h3>
                {product.data.subtitle && (
                  <p class="text-sm font-medium text-primary-600 mb-2">{product.data.subtitle}</p>
                )}
                {product.data.tags && product.data.tags.length > 0 && (
                  <div class="flex flex-wrap gap-1.5 mb-3">
                    {product.data.tags.map((t: string) => (
                      <span class="text-xs bg-gray-100 text-gray-600 px-2 py-0.5 rounded-full">{t}</span>
                    ))}
                  </div>
                )}
              </div>

              {/* Arrow */}
              <div class="shrink-0 self-center">
                <svg class="w-5 h-5 text-gray-300 group-hover:text-primary-500 group-hover:translate-x-1 transition-all" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                </svg>
              </div>
            </a>
          );
        })}
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
