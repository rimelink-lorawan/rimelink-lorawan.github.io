---
---

<section id="contact" class="relative py-20 lg:py-28 bg-gradient-to-br from-primary-900 via-primary-800 to-primary-950 overflow-hidden">
  <!-- Background pattern -->
  <div class="absolute inset-0 opacity-[0.04]" style="background-image: radial-gradient(circle at 25% 50%, #fff 1px, transparent 1px), radial-gradient(circle at 75% 30%, #fff 1px, transparent 1px); background-size: 50px 50px;"></div>
  <div class="absolute top-10 right-[15%] w-80 h-80 bg-accent-500/8 rounded-full blur-3xl"></div>
  <div class="absolute bottom-10 left-[10%] w-96 h-96 bg-blue-400/8 rounded-full blur-3xl"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- CTA Heading -->
    <div class="text-center max-w-3xl mx-auto mb-14">
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-white mb-6 leading-tight">
        准备好开始您的<br class="sm:hidden" />物联网项目了吗？
      </h2>
      <p class="text-lg sm:text-xl text-blue-200/70 leading-relaxed max-w-xl mx-auto">
        技术咨询、产品试用、方案定制，随时为您服务
      </p>
    </div>

    <!-- Contact Cards — glass morphism -->
    <div class="grid sm:grid-cols-3 gap-5 lg:gap-8 mb-12">
      {[
        {
          icon: 'phone',
          title: '电话咨询',
          desc: '工作日 9:00-18:00',
          value: '0731-82236164',
          href: 'tel:0731-82236164',
          cta: '立即拨打',
        },
        {
          icon: 'email',
          title: '邮件联系',
          desc: '我们将在 24 小时内回复',
          value: 'support@rimelink.com',
          href: 'mailto:support@rimelink.com',
          cta: '发送邮件',
        },
        {
          icon: 'location',
          title: '公司地址',
          desc: '---',
          value: '长沙市金星大道518号',
          href: 'javascript:void(0);',
          cta: '',
        },
      ].map((item) => (
        <a
          href={item.href}
          class="group relative bg-white/5 backdrop-blur-sm border border-white/10 rounded-2xl p-6 lg:p-8 hover:bg-white/10 hover:border-white/20 transition-all duration-300 hover:-translate-y-1 block"
        >
          {/* Icon */}
          <div class="w-12 h-12 bg-gradient-to-br from-accent-500/30 to-accent-600/20 rounded-xl flex items-center justify-center mb-5 group-hover:scale-110 transition-transform">
            {item.icon === 'phone' && (
              <svg class="w-6 h-6 text-accent-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            )}
            {item.icon === 'email' && (
              <svg class="w-6 h-6 text-accent-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            )}
            {item.icon === 'location' && (
              <svg class="w-6 h-6 text-accent-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            )}
          </div>

          <h3 class="text-white font-bold text-lg mb-1">{item.title}</h3>
          <p class="text-blue-300/50 text-sm mb-4">{item.desc}</p>
          <p class="text-white/80 font-medium text-sm mb-4">{item.value}</p>

          <span class="inline-flex items-center gap-1.5 text-accent-400 text-sm font-semibold group-hover:gap-2.5 transition-all">
            {item.cta}
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </span>
        </a>
      ))}
    </div>

    {/* Additional info bar */}
    <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
      {[
        { label: 'QQ', value: '1760685983' },
        { label: '微信', value: 'www_rimelink_com' },
        { label: 'QQ群', value: '329061973' },
      ].map((item) => (
        <div class="flex items-center gap-2.5 bg-white/5 backdrop-blur-sm rounded-xl px-3.5 py-2.5 border border-white/10">
          <span class="text-xs font-medium text-blue-300/50 shrink-0">{item.label}</span>
          <span class="text-xs text-blue-200/80 font-mono truncate">{item.value}</span>
        </div>
      ))}
    </div>
  </div>

  <!-- Bottom wave transition to Footer -->
  <div class="absolute bottom-0 left-0 right-0 pointer-events-none">
    <svg viewBox="0 0 1440 60" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full">
      <path d="M0 60L48 55C96 50 192 40 288 37.5C384 35 480 40 576 45C672 50 768 55 864 55C960 55 1056 50 1152 45C1248 40 1344 35 1392 32.5L1440 30V60H1392C1344 60 1248 60 1152 60C1056 60 960 60 864 60C768 60 672 60 576 60C480 60 384 60 288 60C192 60 96 60 48 60H0Z" fill="#0f172a"/>
    </svg>
  </div>
</section>
