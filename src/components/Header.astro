---
const navItems = [
  { label: '首页', href: '/' },
  { label: '产品中心', href: '/products/' },
  { label: '应用案例', href: '/cases/' },
  { label: '文档中心', href: '/docs/' },
  { label: '关于我们', href: '/#about' },
];

let scrolled = false;

if (typeof window !== 'undefined') {
  window.addEventListener('scroll', () => {
    scrolled = window.scrollY > 50;
    const header = document.getElementById('main-header');
    if (header) {
      header.classList.toggle('shadow-lg', scrolled);
      header.classList.toggle('bg-white/95', scrolled);
      header.classList.toggle('backdrop-blur-md', scrolled);
    }
  });
}
---

<header id="main-header" class="fixed top-0 left-0 right-0 z-50 bg-white transition-all duration-300">
  <!-- Top bar -->
  <div class="bg-primary-700 text-white text-sm py-1.5">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex justify-between items-center">
      <span class="flex items-center gap-2">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        Since 2014 · 专业LoRaWAN物联网解决方案
      </span>
      <div class="hidden md:flex items-center gap-4 text-xs">
        <a href="tel:0731-82236164" class="hover:text-accent-300 flex items-center gap-1">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          0731-82236164
        </a>
        <span>|</span>
        <a href="mailto:support@rimelink.com" class="hover:text-accent-300">support@rimelink.com</a>
      </div>
    </div>
  </div>

  <!-- Main nav -->
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16 lg:h-20">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-3 group">
        <div class="w-10 h-10 bg-gradient-to-br from-primary-500 to-primary-700 rounded-lg flex items-center justify-center shadow-md group-hover:shadow-lg">
          <span class="text-white font-bold text-lg">锐</span>
        </div>
        <div>
          <span class="text-xl font-bold text-primary-800 tracking-tight">RimeLink</span>
          <span class="block text-[10px] text-gray-500 -mt-1 tracking-widest">锐米物联</span>
        </div>
      </a>

      <!-- Desktop nav -->
      <div class="hidden lg:flex items-center gap-1">
        {navItems.map((item) => (
          <a
            href={item.href}
            class="px-3 xl:px-4 py-2 rounded-lg text-[15px] font-medium text-gray-700 hover:text-primary-600 hover:bg-primary-50 transition-colors"
          >
            {item.label}
          </a>
        ))}
      </div>

      <!-- CTA button (desktop) -->
      <div class="hidden lg:flex items-center gap-3">
        <a
          href="/#contact"
          class="bg-gradient-to-r from-primary-600 to-primary-700 text-white px-5 py-2.5 rounded-full text-sm font-medium hover:from-primary-700 hover:to-primary-800 shadow-md hover:shadow-lg"
        >
          联系我们
        </a>
      </div>

      <!-- Mobile menu button -->
      <button
        id="mobile-menu-btn"
        class="lg:hidden p-2 rounded-lg hover:bg-gray-100"
        aria-label="打开菜单"
      >
        <svg class="w-6 h-6 text-gray-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="lg:hidden hidden border-t border-gray-100 bg-white">
    <div class="max-w-7xl mx-auto px-4 py-4 space-y-1">
      {navItems.map((item) => (
        <a
          href={item.href}
          class="block px-4 py-3 rounded-xl text-gray-700 hover:text-primary-600 hover:bg-primary-50 font-medium transition-colors"
        >
          {item.label}
        </a>
      ))}
      <a
        href="/#contact"
        class="block mt-3 text-center bg-primary-600 text-white px-5 py-3 rounded-xl font-medium"
      >
        联系我们
      </a>
    </div>
  </div>
</header>

<!-- Spacer for fixed header -->
<div class="h-[105px] lg:h-[117px]"></div>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');

  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
    // Animate hamburger icon
    const svg = btn.querySelector('svg');
    if (!menu?.classList.contains('hidden')) {
      svg?.setAttribute('d', 'M6 18L18 6M6 6l12 12');
    } else {
      svg?.setAttribute('d', 'M4 6h16M4 12h16M4 18h16');
    }
  });
</script>
