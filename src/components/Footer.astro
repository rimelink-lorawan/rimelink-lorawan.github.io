---
const currentYear = new Date().getFullYear();
const footerLinks = {
  products: [
    { label: 'LoRaWAN模组', href: '/products/module/' },
    { label: '室外网关', href: '/products/outdoor-gateway/' },
    { label: '开发板', href: '/products/devkit/' },
  ],
  resources: [
    { label: '文档中心', href: '/docs/' },
    { label: '应用案例', href: '/cases/' },
    { label: '产品中心', href: '/products/' },
    { label: '官网论坛', href: 'http://lora.timeddd.com/forum.php' },
  ],
  company: [
    { label: '关于我们', href: '/#about' },
    { label: '联系我们', href: '/#contact' },
  ],
};
---

<footer class="bg-slate-900 text-gray-300">
  <!-- Main footer -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-5 gap-8">
      {/* Brand column */}
      <div class="col-span-2 md:col-span-4 lg:col-span-1 mb-8 lg:mb-0">
        <a href="/" class="flex items-center gap-3 group mb-6">
          <div class="w-10 h-10 bg-gradient-to-br from-primary-500 to-primary-700 rounded-lg flex items-center justify-center">
            <span class="text-white font-bold text-lg">锐</span>
          </div>
          <div>
            <span class="text-xl font-bold text-white tracking-tight">RimeLink</span>
            <span class="block text-[10px] text-gray-500 -mt-1 tracking-widest">锐米物联</span>
          </div>
        </a>
        <p class="text-sm text-gray-400 leading-relaxed mb-6">
          专业 LoRaWAN 物联网解决方案提供商，致力于为客户提供稳定、安全、低功耗的物联网产品与服务。
        </p>

        {/* Social links */}
        <div class="flex gap-3">
          <a href="#" class="w-9 h-9 bg-slate-800 hover:bg-primary-600 rounded-lg flex items-center justify-center transition-colors" aria-label="QQ">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8z"/><circle cx="12" cy="12" r="3"/></svg>
          </a>
          <a href="#" class="w-9 h-9 bg-slate-800 hover:bg-green-600 rounded-lg flex items-center justify-center transition-colors" aria-label="微信">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M8.691 2.188C3.891 2.188 0 5.476 0 9.53c0 2.212 1.17 4.203 3.002 5.55a.59.59 0 01.213.665l-.39 1.48c-.019.07-.048.141-.048.213 0 .163.13.295.29.295a.326.326 0 00.167-.054l1.903-1.114a.864.864 0 01.717-.098 10.16 10.16 0 002.837.403c.276 0 .543-.027.811-.05-.857-2.578.157-4.972 1.932-6.446 1.703-1.415 3.882-1.98 5.853-1.838-.576-3.583-4.196-6.348-8.596-6.348zM5.785 5.991c.642 0 1.162.529 1.162 1.18a1.17 1.17 0 01-1.162 1.178A1.17 1.17 0 014.623 7.17c0-.651.52-1.18 1.162-1.18zm5.813 0c.642 0 1.162.529 1.162 1.18a1.17 1.17 0 01-1.162 1.178 1.17 1.17 0 01-1.162-1.178c0-.651.52-1.18 1.162-1.18z"/></svg>
          </a>
        </div>
      </div>

      {/* Link columns */}
      <div>
        <h4 class="text-white font-semibold mb-4 text-sm uppercase tracking-wider">产品中心</h4>
        <ul class="space-y-3">
          {footerLinks.products.map((link) => (
            <li><a href={link.href} class="text-sm text-gray-400 hover:text-primary-400 transition-colors">{link.label}</a></li>
          ))}
        </ul>
      </div>

      <div>
        <h4 class="text-white font-semibold mb-4 text-sm uppercase tracking-wider">资源支持</h4>
        <ul class="space-y-3">
          {footerLinks.resources.map((link) => (
            <li><a href={link.href} class="text-sm text-gray-400 hover:text-primary-400 transition-colors" target={link.href.startsWith('http') ? '_blank' : undefined} rel={link.href.startsWith('http') ? 'noopener noreferrer' : undefined}>{link.label}</a></li>
          ))}
        </ul>
      </div>

      <div>
        <h4 class="text-white font-semibold mb-4 text-sm uppercase tracking-wider">关于公司</h4>
        <ul class="space-y-3">
          {footerLinks.company.map((link) => (
            <li><a href={link.href} class="text-sm text-gray-400 hover:text-primary-400 transition-colors">{link.label}</a></li>
          ))}
        </ul>
      </div>

      {/* Working hours */}
      <div>
        <h4 class="text-white font-semibold mb-4 text-sm uppercase tracking-wider">工作时间</h4>
        <div class="bg-slate-800 rounded-xl p-4">
          <p class="text-sm text-gray-400 mb-2">周一至周五</p>
          <p class="text-white font-mono font-medium">09:00 - 17:00</p>
          <div class="mt-3 pt-3 border-t border-slate-700">
            <p class="text-xs text-gray-500">节假日除外</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  {/* Bottom bar */}
  <div class="border-t border-gray-800">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6 flex flex-col sm:flex-row justify-between items-center gap-4">
      <p class="text-xs text-gray-500">
        &copy; {currentYear} 锐米 RimeLink. All rights reserved.
      </p>
      <p class="text-xs text-gray-500">
        Since 2014 · 长沙市金星大道518号
      </p>
    </div>
  </div>
</footer>
