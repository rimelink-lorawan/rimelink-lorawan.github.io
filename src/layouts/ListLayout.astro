---
// Shared layout for list pages (downloads / open-source / cases)
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  subtitle: string;
  badge: string;
}

const { title, subtitle, badge } = Astro.props;
---

<BaseLayout title={`${title} - 锐米 RimeLink`}>
  <Header />
  <main class="min-h-screen">
    {/* Page header */}
    <section class="bg-gradient-to-br from-primary-600 to-primary-800 text-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 lg:py-20">
        <div class="max-w-3xl">
          <div class="inline-flex items-center gap-2 bg-white/20 rounded-full px-4 py-1.5 text-sm mb-4">
            {badge}
          </div>
          <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold mb-4">{title}</h1>
          <p class="text-lg text-white/80">{subtitle}</p>
        </div>
      </div>
    </section>

    {/* Content area */}
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 -mt-8 pb-20">
      <slot />
    </section>
  </main>
  <Footer />
</BaseLayout>
